{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "weWatch · NestJS API",
  "scripts": {
    "dev": "nest build && node --env-file=.env dist/main.js",
    "build": "nest build",
    "start": "node dist/main",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "npx tsx --env-file=.env node_modules/.bin/drizzle-kit migrate",
    "db:seed": "npx tsx --env-file=.env src/db/seed.ts",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/lib-storage": "^3.1044.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.5.0",
    "@types/multer": "^2.1.0",
    "@wewatch/ir-schema": "workspace:*",
    "@wewatch/shared-utils": "workspace:*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "vitest": "^1.6.0"
  }
}
