# =============================================================================
# weWatch · 环境变量示例
# 复制此文件为 .env.local，填入真实值后运行 pnpm bootstrap
# 警告：.env.local 已在 .gitignore，永远不要提交真实密钥
# =============================================================================

# --- 数据库 ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wewatch

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT 认证 ---
JWT_SECRET=change-me-use-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# --- Cloudflare R2 对象存储 ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=wewatch-assets
R2_PUBLIC_URL=https://pub-xxx.r2.dev   # 你的 R2 公开访问域名

# --- AI 生成（Phase 3 启用）---
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...
OPENAI_API_KEY=sk-...   # 用于内容审核

# --- Stripe 支付（Phase 1 后期启用）---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Garmin SDK（Garmin SDK Agent 使用）---
GARMIN_DEVELOPER_KEY_PATH=/path/to/your/developer.key

# --- 监控（可选）---
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
POSTHOG_API_KEY=phc_...
